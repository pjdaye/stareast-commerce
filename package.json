  "bugs": {
    "url": "https://github.com/pjdaye/stareast-commerce/issues"
  },
  "homepage": "https://github.com/pjdaye/stareast-commerce#readme",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "mochawesome": "^7.1.4",
    "supertest": "^7.2.2"
