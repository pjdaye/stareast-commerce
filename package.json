{
  "name": "stareast-commerce",
  "version": "1.0.0",
  "description": "Simple e-commerce REST API with JWT auth and checkout",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "mocha \"test/**/*.spec.js\" --reporter mochawesome --reporter-options reportDir=test/reports,reportFilename=path-coverage,quiet=true",
